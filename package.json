{
    "name": "@enkryptify/cli",
    "version": "0.3.0",
    "bin": {
        "ek": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "scripts": {
        "build": "bun build src/cli.ts --outdir dist --target node --minify",
        "package": "bun build  src/cli.ts --compile --outfile bin/ek",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "typecheck": "tsc --noEmit",
        "build:dev": "./scripts/build-dev.sh",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "bun run build"
    },
    "dependencies": {
        "@t3-oss/env-core": "^0.13.10",
        "axios": "^1.13.6",
        "commander": "^14.0.3",
        "ink": "^6.8.0",
        "ink-select-input": "^6.2.0",
        "ink-spinner": "^5.0.0",
        "ink-text-input": "^6.0.0",
        "keytar": "^7.9.0",
        "open": "^11.0.0",
        "posthog-node": "^5.28.5",
        "prompts": "^2.4.2",
        "react": "^19.2.4",
        "react-devtools-core": "^7.0.1",
        "semver": "^7.7.4",
        "zod": "^4.3.6"
    },
    "overrides": {
        "picomatch": ">=4.0.4"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/node": "^24.12.0",
        "@types/prompts": "^2.4.9",
        "@types/react": "^19.2.14",
        "@types/semver": "^7.7.1",
        "@vitest/coverage-v8": "^4.1.0",
        "msw": "^2.12.14",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.56.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
